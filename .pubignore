# .pubignore - Controls what gets published to pub.dev

# Ignore common development and build files
.dart_tool/
.packages
.pub/
build/
coverage/
*.log

# Ignore the example app's build artifacts (but keep the example source code)
example/build/
example/.dart_tool/
example/ios/Pods/
example/android/.gradle/

# Explicitly include the LICENSE file (this overrides .gitignore)
!LICENSE

# Optional: If you have other files you don't want to publish
# !.github/          # Uncomment if you want to exclude GitHub workflows